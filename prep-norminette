}

resolve_norm_log_file_path() {
    local target_dir="$1"
    local norm_path="$2"

    if [[ "$norm_path" == /* ]]; then
        printf '%s\n' "$norm_path"
        return
    fi
    if [[ -f "$norm_path" ]]; then
        abs_file "$norm_path" && return
    fi
    if [[ -f "$target_dir/$norm_path" ]]; then
        abs_file "$target_dir/$norm_path" && return
    fi
    printf '%s\n' "$target_dir/$norm_path"
}

run_norminette_whitespace_loop() {
    local target_dir="$1"
    local norm_bin="$2"
    local log_file="$target_dir/.prep-norminette.log"
    local pass
    local ws_count
    local norm_path
    local resolved
    local fixed_any

    for pass in $(seq 1 "$MAX_NORM_PASSES"); do
        run_norminette_log "$norm_bin" "$target_dir" "$log_file"
        ws_count="$(count_whitespace_errors_in_log "$log_file")"

        if [[ "$ws_count" -eq 0 ]]; then
            echo "Norminette whitespace checks passed (pass $pass)."
            echo "Norminette log written to '$log_file'."
            return 0
        fi

        fixed_any=0
        while IFS= read -r norm_path; do
            [[ -n "$norm_path" ]] || continue
            resolved="$(resolve_norm_log_file_path "$target_dir" "$norm_path")"
            if [[ -f "$resolved" ]]; then
                if normalize_file "$resolved"; then
                    fixed_any=1
                fi
            fi
        done < <(collect_whitespace_error_files "$log_file")

        if [[ "$fixed_any" -eq 0 ]]; then
            break
        fi
    done

    run_norminette_log "$norm_bin" "$target_dir" "$log_file"
    ws_count="$(count_whitespace_errors_in_log "$log_file")"
    if [[ "$ws_count" -gt 0 ]]; then
        die "norminette still reports $ws_count whitespace-related error(s). See '$log_file'."
    fi

    echo "Norminette whitespace checks passed."
    echo "Norminette log written to '$log_file'."
}

