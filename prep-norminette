#!/usr/bin/env bash

set -euo pipefail

die() {
    echo "Error: $*" >&2
    exit 1
}

warn() {
    echo "Warning: $*" >&2
}

usage() {
    echo "Usage: $0 <folder>" >&2
    echo "Examples:" >&2
    echo "  Fill scripts/prep.config first (SCRIPTS_DIR and CODE_DIR)." >&2
    echo "  $0 c-01" >&2
}

require_cmd() {
    command -v "$1" >/dev/null 2>&1 || die "required command '$1' not found."
}

script_dir="$(cd "$(dirname "$0")" && pwd)"
config_file="$script_dir/prep.config"

tmp_files=()

cleanup() {
    local f

    for f in "${tmp_files[@]:-}"; do
        if [[ -n "$f" && -e "$f" ]]; then
            rm -f "$f"
        fi
    done
}

trap cleanup EXIT

for cmd in awk cat chmod cmp dirname find mktemp mv pwd sort; do
    require_cmd "$cmd"
done

MAX_NORM_PASSES=3

abs_dir() {
    local p="$1"

    [[ -d "$p" ]] || return 1
    (cd "$p" && pwd)
}

abs_file() {
    local f="$1"

    [[ -f "$f" ]] || return 1
    printf '%s\n' "$(cd "$(dirname "$f")" && pwd)/$(basename "$f")"
}

resolve_dir_arg() {
    local raw="$1"

    if [[ "$raw" == /* ]]; then
        abs_dir "$raw" || return 1
        return
    fi

    if [[ -d "$raw" ]]; then
        abs_dir "$raw" || return 1
        return
    fi

    abs_dir "$PWD/$raw" || return 1
}

is_config_mode() {
    local arg

    [[ $# -gt 0 ]] || return 1
    for arg in "$@"; do
        [[ "$arg" == *=* ]] || return 1
    done
    return 0
}

load_config() {
    [[ -f "$config_file" ]] || die "missing '$config_file'. Fill SCRIPTS_DIR and CODE_DIR first."

    # shellcheck disable=SC1090
    source "$config_file"

    [[ -n "${SCRIPTS_DIR:-}" ]] || die "SCRIPTS_DIR is not set in '$config_file'."
    [[ -n "${CODE_DIR:-}" ]] || die "CODE_DIR is not set in '$config_file'."

    abs_dir "$SCRIPTS_DIR" >/dev/null || die "SCRIPTS_DIR '$SCRIPTS_DIR' is not a readable directory."
    code_root="$(abs_dir "$CODE_DIR")" || die "CODE_DIR '$CODE_DIR' is not a readable directory."
}

write_config() {
    local scripts_path="$1"
    local code_path="$2"
    local username="$3"
    local email="$4"

    {
        printf 'SCRIPTS_DIR=%q\n' "$scripts_path"
        printf 'CODE_DIR=%q\n' "$code_path"
        if [[ -n "$username" ]]; then
            printf 'PREP_USERNAME=%q\n' "$username"
        fi
        if [[ -n "$email" ]]; then
            printf 'PREP_EMAIL=%q\n' "$email"
        fi
    } > "$config_file"
}

configure_only() {
    local scripts_path="$script_dir"
    local code_path=""
    local username=""
    local email=""
    local key
    local value
    local arg

    if [[ -f "$config_file" ]]; then
        # shellcheck disable=SC1090
        source "$config_file"
        username="${PREP_USERNAME:-}"
        email="${PREP_EMAIL:-}"
    fi

    for arg in "$@"; do
        key="${arg%%=*}"
        value="${arg#*=}"
        case "$key" in
            scripts)
                scripts_path="$(resolve_dir_arg "$value")" || die "invalid scripts directory '$value'."
                ;;
            code)
                code_path="$(resolve_dir_arg "$value")" || die "invalid code directory '$value'."
                ;;
            username)
                username="$value"
                ;;
            email)
                email="$value"
                ;;
            *)
                die "unknown configuration key '$key'. Supported keys: scripts, code, username, email."
                ;;
        esac
    done

    [[ -d "$scripts_path" ]] || die "scripts directory '$scripts_path' does not exist."
    [[ -d "$code_path" ]] || die "code directory '$code_path' does not exist."

    write_config "$scripts_path" "$code_path" "$username" "$email"

    echo "Configuration saved in '$config_file'."
    echo "scripts=$scripts_path"
    echo "code=$code_path"
    if [[ -n "$username" ]]; then
        echo "username=$username"
    fi
    if [[ -n "$email" ]]; then
        echo "email=$email"
    fi
    echo "No scripts were executed."
}

resolve_target_dir() {
    local input_path="$1"

    if [[ "$input_path" == /* && -d "$input_path" ]]; then
        abs_dir "$input_path" || die "failed to resolve '$input_path'."
        return
    fi

    if [[ -d "$code_root/$input_path" ]]; then
        abs_dir "$code_root/$input_path" || die "failed to resolve '$code_root/$input_path'."
        return
    fi

    if [[ -d "$input_path" ]]; then
        abs_dir "$input_path" || die "failed to resolve '$input_path'."
        return
    fi

    die "folder '$input_path' not found."
}

find_norminette_bin() {
    local candidate

    if [[ -n "${NORMINETTE_BIN:-}" && -x "$NORMINETTE_BIN" ]]; then
        printf '%s\n' "$NORMINETTE_BIN"
        return 0
    fi

    candidate="$(command -v norminette 2>/dev/null || true)"
    if [[ -n "$candidate" && -x "$candidate" ]]; then
        printf '%s\n' "$candidate"
        return 0
    fi

    for candidate in \
        "$script_dir/../.venv/bin/norminette" \
        "$code_root/.venv/bin/norminette" \
        "$PWD/.venv/bin/norminette" \
        "$(dirname "$code_root")/.venv/bin/norminette" \
        "$script_dir/../code/.venv/bin/norminette" \
        "$(dirname "$script_dir")/.venv/bin/norminette"; do
        if [[ -x "$candidate" ]]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done

    return 1
}

run_norminette_log() {
    local norm_bin="$1"
    local target="$2"
    local out_log="$3"

    "$norm_bin" "$target" > "$out_log" 2>&1 || true
}

is_whitespace_error_code() {
    local code="$1"

    case "$code" in
        SPACE_REPLACE_TAB|TOO_FEW_TAB|TOO_MANY_TAB|CONSECUTIVE_SPC|SPC_BEFORE_NL|EMPTY_LINE_FUNCTION|SPACE_EMPTY_LINE|SPACE_AFTER_KW|RETURN_PARENTHESIS|EMPTY_LINE_EOF)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

count_whitespace_errors_in_log() {
    local log_file="$1"

    awk '
/^Error:[[:space:]]*[A-Z_]+/ {
    if (match($0, /^Error:[[:space:]]*([A-Z_]+)/, m)) {
        code = m[1];
        if (code == "SPACE_REPLACE_TAB" || code == "TOO_FEW_TAB" || code == "TOO_MANY_TAB" || code == "CONSECUTIVE_SPC" || code == "SPC_BEFORE_NL" || code == "EMPTY_LINE_FUNCTION" || code == "SPACE_EMPTY_LINE" || code == "SPACE_AFTER_KW" || code == "RETURN_PARENTHESIS" || code == "EMPTY_LINE_EOF")
            count++;
    }
}
END {
    print count + 0;
}
' "$log_file"
}

collect_whitespace_error_files() {
    local log_file="$1"

    awk '
/: Error!$/ {
    file = $0;
    sub(/: Error!$/, "", file);
    current = file;
    next;
}
/^Error:[[:space:]]*[A-Z_]+/ {
    if (current == "")
        next;
    if (match($0, /^Error:[[:space:]]*([A-Z_]+)/, m)) {
        code = m[1];
        if (code == "SPACE_REPLACE_TAB" || code == "TOO_FEW_TAB" || code == "TOO_MANY_TAB" || code == "CONSECUTIVE_SPC" || code == "SPC_BEFORE_NL" || code == "EMPTY_LINE_FUNCTION" || code == "SPACE_EMPTY_LINE" || code == "SPACE_AFTER_KW" || code == "RETURN_PARENTHESIS" || code == "EMPTY_LINE_EOF")
            print current;
    }
